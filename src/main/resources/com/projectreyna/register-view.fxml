<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.projectreyna.RegisterController"
      alignment="CENTER"
      spacing="10.0"
      prefWidth="420.0"
      prefHeight="680.0">

    <padding>
        <Insets top="30.0"
                right="30.0"
                bottom="30.0"
                left="30.0"/>
    </padding>

    <Label text="Create Account">
        <font>
            <Font name="System Bold" size="26.0"/>
        </font>
    </Label>

    <Label text="Register for Food Delivery"/>

    <TextField fx:id="nameField"
               promptText="Full Name"
               maxWidth="260.0"/>

    <TextField fx:id="emailField"
               promptText="Email"
               maxWidth="260.0"/>

    <TextField fx:id="phoneField"
               promptText="Phone Number"
               maxWidth="260.0"/>

    <TextField fx:id="addressField"
               promptText="Delivery Address"
               maxWidth="260.0"/>

    <PasswordField fx:id="passwordField"
                   promptText="Password"
                   maxWidth="260.0"/>

    <PasswordField fx:id="confirmPasswordField"
                   promptText="Confirm Password"
                   maxWidth="260.0"/>

    <ComboBox fx:id="roleComboBox"
              promptText="Select Account Type"
              prefWidth="260.0"
              maxWidth="260.0"/>

    <Button text="Register"
            onAction="#handleRegister"
            defaultButton="true"
            prefWidth="260.0"
            maxWidth="260.0"/>

    <Hyperlink text="Already have an account? Log in"
               onAction="#handleBackToLogin"/>

    <Label fx:id="messageLabel"
           maxWidth="320.0"
           wrapText="true"
           style="-fx-text-fill: red;"/>

</VBox>
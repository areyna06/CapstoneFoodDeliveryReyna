<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="14.0" prefWidth="420.0" prefHeight="560.0"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.projectreyna.TrackingController">
    <padding>
        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
    </padding>
    <children>
        <Label text="Track Your Order">
            <font>
                <Font name="System Bold" size="24.0"/>
            </font>
        </Label>
        <Label fx:id="statusLabel" text="Status: Pending">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <ProgressBar fx:id="progressBar" prefWidth="300.0" progress="0.0"/>
        <Label fx:id="detailLabel" text="" wrapText="true"/>
        <Button fx:id="rateButton" text="Rate Order" onAction="#handleRateOrder" maxWidth="260.0" disable="true"/>
        <Button text="Back to Restaurants" onAction="#handleBackToRestaurants" maxWidth="260.0"/>
    </children>
</VBox>